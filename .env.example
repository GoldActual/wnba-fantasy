# Copy to .env (which is gitignored) and fill in.
#
# Generate a strong random token:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
#
# This token gates all write endpoints (draft picks, transactions, manual
# sync). Reads stay public so the Tailscale Funnel URL is browseable
# without it. Anyone with this token has admin rights for this app, so
# treat it like a password.
WNBA_ADMIN_TOKEN=replace-me-with-a-long-random-string
